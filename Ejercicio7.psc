Proceso EJERCICIO7
	
	Definir capital, tiempo, interes, tasa Como Real
	
	tasa <- 0.10
	
	Escribir "La tasa de interes es: ", tasa
	Escribir "Ingrese el capital:"
	Leer capital
	
	Escribir "Ingrese el tiempo:"
	Leer tiempo
	
	interes <- capital * tasa * tiempo
	
	Escribir "El interes simple es: ", interes
	
FinProceso